# Core databases
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
MONGODB_URI="mongodb+srv://USER:PASSWORD@HOST/DATABASE?appName=APP_NAME"
MONGODB_DB="mockr_questions"
COMPANY_QUESTIONS_MONGODB_DB="company_questions"

# Redis
REDIS_URL="redis://localhost:6379"
BULLMQ_REDIS_URL=""
UPSTASH_REDIS_REST_URL="https://your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_SECRET_KEY="your-supabase-secret-key"

# Local load-test auth. Never enable in production.
LOAD_TEST_AUTH_ENABLED="false"
LOAD_TEST_JWT_SECRET=""

# AI providers
XAI_API_KEY="your-xai-api-key"
# Gemini-backed features (tutor, resume analysis, report generation, AI screening).
# Leave this BLANK to route all Gemini-backed features through the Groq fallback below.
GOOGLE_GENERATIVE_AI_API_KEY="your-google-generative-ai-api-key"
# Groq fallback — used automatically whenever GOOGLE_GENERATIVE_AI_API_KEY is empty.
GROQ_API_KEY="your-groq-api-key"
GROQ_MODEL="openai/gpt-oss-120b"

# Judge0
# For real contests, use a dedicated/self-hosted Judge0 endpoint, not RapidAPI.
JUDGE0_PROVIDER="self-hosted"
JUDGE0_API_URL="https://judge0.example.com"
JUDGE0_API_KEY="your-judge0-api-key"
JUDGE0_AUTH_HEADER="X-Auth-Token"
JUDGE0_HOST="judge0.example.com"
JUDGE0_ALLOW_SHARED_ENDPOINT="false"
JUDGE0_EXECUTION_CONCURRENCY="200"
JUDGE0_CPU_TIME_LIMIT_SECONDS="2"
JUDGE0_WALL_TIME_LIMIT_SECONDS="4"
JUDGE0_MEMORY_LIMIT_KB="262144"
JUDGE0_MAX_OUTPUT_SIZE="1048576"
JUDGE0_POLL_MAX_ATTEMPTS="120"
JUDGE0_POLL_INITIAL_DELAY_MS="1000"
JUDGE0_POLL_MAX_DELAY_MS="5000"
JUDGE0_ENABLE_PER_PROCESS_AND_THREAD_TIME_LIMIT=""
JUDGE0_ENABLE_PER_PROCESS_AND_THREAD_MEMORY_LIMIT=""
JUDGE0_DS_PYTHON_LANGUAGE_ID="89"

# Legacy/API Judge0 split settings used by older API paths.
# Standard CE is used for DSA, SQL, and normal GenAI coding.
JUDGE0_CE_URL="https://judge0-ce.example.com"
JUDGE0_CE_HOST="judge0-ce.example.com"
# Extra CE is used only for Data Science coding tasks that need numpy/pandas/sklearn.
JUDGE0_EXTRA_CE_URL="https://judge0-extra-ce.example.com"
JUDGE0_EXTRA_CE_HOST="judge0-extra-ce.example.com"
JUDGE0_CHUNK_CONCURRENCY="4"

# Contest submission queue.
# Production/load testing must use BullMQ with a TCP Redis URL (redis:// or rediss://).
# Do not put the Upstash REST HTTPS URL here.
QUEUE_BACKEND="auto"
QUEUE_REDIS_URL=""
QUEUE_CONCURRENCY="100"
QUEUE_MAX_ATTEMPTS="2"
QUEUE_RETRY_BASE_DELAY_MS="2000"
BULLMQ_DRAIN_DELAY_SECONDS="300"
BULLMQ_STALLED_INTERVAL_MS="300000"
BULLMQ_LOCK_DURATION_MS="180000"
BULLMQ_MAX_STALLED_COUNT="2"
JUDGE0_QUEUE_CONCURRENCY="10"
JUDGE0_QUEUE_ATTEMPTS="2"
JUDGE0_QUEUE_BACKOFF_MS="5000"
JUDGE0_QUEUE_REMOVE_ON_COMPLETE_AGE="86400"
JUDGE0_QUEUE_REMOVE_ON_COMPLETE_COUNT="10000"
JUDGE0_QUEUE_REMOVE_ON_FAIL_AGE="604800"
JUDGE0_QUEUE_REMOVE_ON_FAIL_COUNT="5000"

# Runtime
NODE_ENV="development"
METRICS_ENABLED="false"
API_HOST="::"
API_PORT="3001"
P2P_PORT="3004"
PORT="3001"
WS_PORT="3002"
JWT_SECRET="change-me-in-production"
# Additional CORS origins (comma-separated list)
# Example: "http://localhost:3000,http://127.0.0.1:3000,http://localhost:3003,http://127.0.0.1:3003,https://staging.practers.com"
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://127.0.0.1:3001"
NEXT_PUBLIC_WS_URL="ws://127.0.0.1:3001"
NEXT_PUBLIC_P2P_URL="http://localhost:3004"
NEXT_PUBLIC_VOICE_AUDIO_TRANSPORT="binary"
NEXT_PUBLIC_COMPANY_URL="http://localhost:3003"
COMPANY_FRONTEND_URL="http://localhost:3003/companies"
COMPANY_BASE_PATH="/companies"
ADMIN_EMAILS="admin@example.com"
SECURE_OA_TOKEN_SECRET="change-me-secure-oa-token-secret"

# Object storage
S3_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
S3_BUCKET="resume-bucket"
S3_ACCESS_KEY="your-r2-access-key"
S3_SECRET_KEY="your-r2-secret-key"
R2_AVATAR_BUCKET="practers-avatars"
R2_AVATAR_PUBLIC_URL="https://your-avatar-public-domain"
R2_DATASET_PUBLIC_URL="https://your-dataset-public-domain"
R2_RECORDINGS_ENDPOINT="https://your-recordings-account-id.r2.cloudflarestorage.com"
R2_RECORDINGS_ACCESS_KEY="your-recordings-r2-access-key"
R2_RECORDINGS_SECRET_KEY="your-recordings-r2-secret-key"
R2_RECORDINGS_BUCKET="interview-recordings"
R2_BLOG_IMAGES_BUCKET="your-blog-images-bucket"
R2_BLOG_IMAGES_PUBLIC_URL="https://your-blog-images-public-domain"
BLOG_TEAM_AUTHOR_EMAILS="author1@example.com,author2@example.com"
BLOG_TEAM_DISPLAY_NAME="Practers team"
BLOG_TEAM_AVATAR_URL="/logo_small.svg"

# Email and notifications
RESEND_API_KEY="your-resend-api-key"
RESEND_AUTH_API_KEY="your-resend-auth-api-key"
RESEND_VERIFIED_DOMAIN="example.com"
ADMIN_NOTIFICATION_EMAIL="admin@example.com"

# Payments
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"
NEXT_PUBLIC_RZP_PLAN_PLUS_MONTHLY="your-plus-monthly-plan-id"
NEXT_PUBLIC_RZP_PLAN_PLUS_QUARTERLY="your-plus-quarterly-plan-id"
NEXT_PUBLIC_RZP_PLAN_PRO_MONTHLY="your-pro-monthly-plan-id"
NEXT_PUBLIC_RZP_PLAN_PRO_QUARTERLY="your-pro-quarterly-plan-id"
NEXT_PUBLIC_RZP_PLAN_MAX_MONTHLY="your-max-monthly-plan-id"
NEXT_PUBLIC_RZP_PLAN_MAX_QUARTERLY="your-max-quarterly-plan-id"

# Voice/phone providers
DEEPGRAM_API_KEY="your-deepgram-api-key"
MSG91_WIDGET_ID="your-msg91-widget-id"
MSG91_WIDGET_TOKEN="your-msg91-widget-token"
MSG91_AUTH_KEY="your-msg91-auth-key"
NEXT_PUBLIC_MSG91_WIDGET_ID="your-msg91-widget-id"
NEXT_PUBLIC_MSG91_WIDGET_TOKEN="your-msg91-widget-token"

# Encryption
ENCRYPTION_KEY="64-character-hex-encryption-key"

# Feature flags
TUTOR_AGENT_V2="true"
NEXT_PUBLIC_TUTOR_AGENT_V2="true"
