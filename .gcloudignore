# This file specifies files that are *not* uploaded to Google Cloud
# using gcloud. It follows the same syntax as .gitignore, with the addition of
# "#!include" directives (which insert the entries of the given .gitignore-style
# file at that point).

#!include:.gitignore

# Node modules (will be installed during build)
node_modules/
.pnp
.pnp.js

# Testing
coverage/
.nyc_output/

# Build outputs (will be generated during build)
dist/
build/
.next/
out/

# Development files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Temporary files
tmp/
temp/
*.tmp
tmp-*

# Documentation
*.md
!README.md

# Git
.git/
.gitignore

# Turbo
.turbo/

# Test files
*.test.ts
*.test.js
*.spec.ts
*.spec.js
__tests__/

# Scripts
scripts/
test-*.js
test-*.py
check-*.js
debug-*.js
fix-*.js
simulate-*.js
capture-*.js
clear-*.js
invalidate-*.js

# SQL files
*.sql

# Other
Questions/
sys_design/
ide-demo/
stitch/
Practers_Legal_Documents.docx
