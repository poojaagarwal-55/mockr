{
    "name": "@interviewforge/api",
    "version": "0.1.0",
    "type": "module",
    "private": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc || true",
        "start": "node dist/index.js",
        "worker:code-execution": "tsx src/workers/code-execution-worker.ts",
        "start:worker:code-execution": "node dist/workers/code-execution-worker.js",
        "type-check": "tsc --noEmit",
        "test": "jest --config ../../jest.config.cjs --selectProjects api",
        "test:regression:behavioural": "tsx src/services/agent/behavioural-flow.check.ts",
        "test:regression:interview-flow": "tsx src/services/agent/interview-flow.check.ts",
        "test:smoke:interview-runtime": "tsx src/services/agent/interview-runtime-smoke.check.ts",
        "test:regression:all": "npm run test:regression:behavioural && npm run test:regression:interview-flow",
        "fix-question-ids": "tsx src/scripts/fix-question-ids.ts",
        "seed:problem-solving-cases": "tsx src/scripts/seed-problem-solving-cases.ts",
        "seed:ds-coding-sklearn": "tsx src/scripts/seed-ds-coding-sklearn.ts",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1003.0",
        "@aws-sdk/s3-request-presigner": "^3.1007.0",
        "@fastify/cookie": "^11.0.0",
        "@fastify/cors": "^10.0.0",
        "@fastify/multipart": "^9.4.0",
        "@fastify/static": "^9.0.0",
        "@google/genai": "^1.46.0",
        "@interviewforge/db": "*",
        "@interviewforge/shared": "*",
        "@supabase/supabase-js": "^2.49.0",
        "@upstash/redis": "^1.37.0",
        "axios": "^1.15.2",
        "bcrypt": "^5.1.1",
        "bullmq": "^5.78.0",
        "dotenv": "^16.4.0",
        "fastify": "^5.2.0",
        "fastify-plugin": "^5.0.0",
        "handlebars": "^4.7.9",
        "ioredis": "^5.11.1",
        "mime": "^4.1.0",
        "mongoose": "^9.3.3",
        "openai": "^6.32.0",
        "pdf-parse": "^1.1.1",
        "pino-pretty": "^13.0.0",
        "razorpay": "^2.9.6",
        "resend": "^6.10.0",
        "socket.io": "^4.8.3",
        "ua-parser-js": "^2.0.9",
        "undici": "^7.24.4",
        "uuid": "^13.0.0",
        "ws": "^8.19.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/node": "^22.13.0",
        "@types/pdf-parse": "^1.1.5",
        "@types/uuid": "^10.0.0",
        "@types/ws": "^8.18.1",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0"
    }
}
