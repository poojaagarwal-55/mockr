# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@host:5432/database
DIRECT_URL=postgresql://user:password@host:5432/database

# Redis (Upstash)
REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Judge0 API
# For real contests, use a dedicated/self-hosted Judge0 endpoint, not RapidAPI.
JUDGE0_PROVIDER=self-hosted
JUDGE0_API_URL=https://judge0.your-domain.example
JUDGE0_CE_URL=https://judge0-ce.your-domain.example
JUDGE0_EXTRA_CE_URL=https://judge0-extra-ce.your-domain.example
JUDGE0_API_KEY=your-judge0-auth-token
JUDGE0_AUTH_HEADER=X-Auth-Token
JUDGE0_HOST=
JUDGE0_CE_HOST=
JUDGE0_EXTRA_CE_HOST=
JUDGE0_ALLOW_SHARED_ENDPOINT=false
JUDGE0_EXECUTION_CONCURRENCY=200
JUDGE0_CHUNK_CONCURRENCY=4
JUDGE0_CPU_TIME_LIMIT_SECONDS=2
JUDGE0_WALL_TIME_LIMIT_SECONDS=4
JUDGE0_MEMORY_LIMIT_KB=262144
JUDGE0_POLL_MAX_ATTEMPTS=120
JUDGE0_POLL_INITIAL_DELAY_MS=1000
JUDGE0_POLL_MAX_DELAY_MS=5000

# Contest submission queue
# Production/load testing must use BullMQ with a TCP Redis URL (redis:// or rediss://).
QUEUE_BACKEND=auto
QUEUE_REDIS_URL=
QUEUE_CONCURRENCY=100
QUEUE_MAX_ATTEMPTS=2
QUEUE_RETRY_BASE_DELAY_MS=2000
BULLMQ_DRAIN_DELAY_SECONDS=300
BULLMQ_STALLED_INTERVAL_MS=300000
BULLMQ_LOCK_DURATION_MS=180000
BULLMQ_MAX_STALLED_COUNT=2

# Supabase (for authentication)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_SECRET_KEY=your_secret_key_here

# MongoDB (for question bank)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/database

# Admin Configuration
ADMIN_EMAILS=admin@example.com

# WebSocket
WS_PORT=3002
