# Copy to secrets.env (gitignored) and fill the values, then:
#   SECRETS_FROM=file:secrets.env ./migrate.sh secrets
# OR skip this file entirely and pull straight from GCP:
#   SECRETS_FROM=gcp ./migrate.sh secrets     (needs GCP billing re-enabled)
#
# Keys are the GCP Secret Manager secret names — do not rename them.

# ── Databases ───────────────────────────────────────────────────────────────
database-url=
direct-url=
mongodb-uri=

# ── Redis (Upstash) ─────────────────────────────────────────────────────────
redis-url=
p2p-redis-url=
queue-redis-url=
upstash-redis-rest-url=
upstash-redis-rest-token=

# ── Supabase ────────────────────────────────────────────────────────────────
next-public-supabase-url=
next-public-supabase-anon-key=
supabase-service-role-key=

# ── AI / LLM / voice ────────────────────────────────────────────────────────
xai-api-key=
google-generative-ai-api-key=
groq-api-key=
deepgram-api-key=
tutor-agent-v2=

# ── Judge0 (RapidAPI) ───────────────────────────────────────────────────────
judge0-api-url=
judge0-api-key=
judge0-chunk-concurrency=

# ── Object storage (S3-compatible + Cloudflare R2) ──────────────────────────
s3-endpoint=
s3-bucket=
s3-access-key=
s3-secret-key=
r2-avatar-bucket=
r2-avatar-public-url=
r2-blog-images-bucket=
r2-blog-images-public-url=
r2-recordings-endpoint=
r2-recordings-access-key=
r2-recordings-secret-key=
r2-recordings-bucket=

# ── Auth / crypto ───────────────────────────────────────────────────────────
jwt-secret=
encryption-key=

# ── Payments (Razorpay) ─────────────────────────────────────────────────────
razorpay-key-id=
razorpay-key-secret=
razorpay-webhook-secret=

# ── Email (Resend) ──────────────────────────────────────────────────────────
resend-api-key=
resend-auth-api-key=
resend-verified-domain=
admin-notification-email=
admin-emails=

# ── SMS / OTP (MSG91) ───────────────────────────────────────────────────────
msg91-widget-id=
msg91-widget-token=
msg91-auth-key=
msg91-sender-id=

# ── Frontend origins / misc ─────────────────────────────────────────────────
frontend-url=
company-frontend-url=
contest-allowed-origins=

# ── WebRTC TURN (Cloudflare) ────────────────────────────────────────────────
cloudflare-turn-key-id=
cloudflare-turn-api-token=

# ── Blog author identity ────────────────────────────────────────────────────
BLOG_TEAM_AUTHOR_EMAILS=
BLOG_TEAM_DISPLAY_NAME=
BLOG_TEAM_AVATAR_URL=
