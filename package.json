{
  "name": "interviewforge",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:b2b": "turbo dev --filter=@interviewforge/api --filter=@interviewforge/company",
    "dev:b2c": "turbo dev --filter=@interviewforge/api --filter=@interviewforge/web --filter=@interviewforge/contest-service",
    "dev:company": "npm run dev --workspace=@interviewforge/company",
    "build": "turbo build",
    "lint": "turbo lint",
    "check:license-policy": "node scripts/check-license-policy.mjs",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:regression:behavioural": "npm run test:regression:behavioural --workspace=@interviewforge/api",
    "test:regression:interview-flow": "npm run test:regression:interview-flow --workspace=@interviewforge/api",
    "test:regression:all": "npm run test:regression:all --workspace=@interviewforge/api",
    "test:smoke:interview-runtime": "npm run test:smoke:interview-runtime --workspace=@interviewforge/api",
    "test:watch": "turbo test -- --watch",
    "db:generate": "npm run generate --workspace=@interviewforge/db",
    "db:push": "npm run push --workspace=@interviewforge/db",
    "db:seed": "npm run seed --workspace=@interviewforge/db",
    "db:studio": "npm run studio --workspace=@interviewforge/db",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.1.2",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@11.0.0",
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@studio-freight/lenis": "^1.0.42",
    "dotenv": "^17.4.1",
    "eslint": "10.1.0",
    "luxon": "^3.7.2",
    "mongodb": "^7.1.1",
    "party-js": "^2.2.0",
    "puppeteer": "^24.40.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  }
}
