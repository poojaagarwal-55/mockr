generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                                                   String                              @id @default(uuid())
  email                                                String                              @unique
  fullName                                             String                              @map("full_name")
  role                                                 String                              @default("user")
  placementCollegeEmailDomain                         String?                             @map("placement_college_email_domain")
  contestInstructionTemplate                           String?                             @map("contest_instruction_template") @db.Text
  avatarUrl                                            String?                             @map("avatar_url")
  createdAt                                            DateTime                            @default(now()) @map("created_at")
  updatedAt                                            DateTime                            @updatedAt @map("updated_at")
  country                                              String?
  mobile                                               String?
  username                                             String?                             @unique
  timezone                                             String?
  onboardingCompleted                                  Boolean                             @default(false) @map("onboarding_completed")
  onboardingCompany                                    String?                             @map("onboarding_company")
  onboardingField                                      String?                             @map("onboarding_field")
  onboardingPosition                                   String?                             @map("onboarding_position")
  onboardingTimeline                                   String?                             @map("onboarding_timeline")
  onboardingTrack                                      String?                             @map("onboarding_track")
  birthday                                             DateTime?
  education                                            Json?                               @map("education")
  gender                                               String?
  githubUrl                                            String?                             @map("github_url")
  linkedinUrl                                          String?                             @map("linkedin_url")
  location                                             String?
  readmeUrl                                            String?                             @map("readme_url")
  skills                                               String[]                            @default([])
  twitterUrl                                           String?                             @map("twitter_url")
  website                                              String?
  workExperience                                       Json?                               @map("work_experience")
  currentStreak                                        Int                                 @default(0) @map("current_streak")
  longestStreak                                        Int                                 @default(0) @map("longest_streak")
  lastActivityDate                                     DateTime?                           @map("last_activity_date") @db.Timestamp(6)
  emailVerified                                        Boolean                             @default(false) @map("email_verified")
  emailVerifiedAt                                      DateTime?                           @map("email_verified_at")
  mobileVerified                                       Boolean                             @default(false) @map("mobile_verified")
  mobileVerifiedAt                                     DateTime?                           @map("mobile_verified_at")
  isExpert                                             Boolean                             @default(false) @map("is_expert")
  lastLoginAt                                          DateTime?                           @map("last_login_at")
  lastLoginIp                                          String?                             @map("last_login_ip")
  lastLoginLocation                                    String?                             @map("last_login_location")
  deviceToken                                          String?                             @map("device_token")
  deviceTokenCreatedAt                                 DateTime?                           @map("device_token_created_at")
  acceptedActionPlans                                  AcceptedActionPlan[]
  blog_comments                                        blog_comments[]
  blog_posts                                           blog_posts[]                        @relation("blog_author")
  blog_reactions                                       blog_reactions[]
  couponRedemptions                                    CouponRedemption[]
  couponRevocations                                    CouponRevocation[]
  creditLedger                                         CreditLedger[]
  creditWallet                                         CreditWallet?
  customQuestionSheets                                 CustomQuestionSheet[]
  reports                                              EvaluationReport[]
  featureUsage                                         FeatureUsage[]
  githubIntegration                                    GitHubIntegration?
  hourlySubmissions                                    HourlySubmissionCounter[]
  jobApplyProfile                                      JobApplyProfile?
  recordings                                           InterviewRecording[]
  sessions                                             InterviewSession[]
  latexResumes                                         LatexResume[]
  loginHistory                                         LoginHistory[]
  passwordResetTokens                                  PasswordResetToken[]
  payments                                             Payment[]
  peer_feedback_peer_feedback_ratee_user_idTousers     peer_feedback[]                     @relation("peer_feedback_ratee_user_idTousers")
  peer_feedback_peer_feedback_rater_user_idTousers     peer_feedback[]                     @relation("peer_feedback_rater_user_idTousers")
  peer_invites_peer_invites_accepted_by_user_idTousers peer_invites[]                      @relation("peer_invites_accepted_by_user_idTousers")
  peer_invites_peer_invites_inviter_user_idTousers     peer_invites[]                      @relation("peer_invites_inviter_user_idTousers")
  peer_queue_tickets                                   peer_queue_tickets[]
  peer_session_messages                                peer_session_messages[]
  peer_session_participants                            peer_session_participants[]
  peer_session_question_assignments                    peer_session_question_assignments[]
  peer_sessions                                        peer_sessions[]
  peer_skill_history                                   peer_skill_history[]
  peer_skill_profiles                                  peer_skill_profiles?
  questionReports                                      QuestionReport[]
  questionSheets                                       QuestionSheet[]
  resumes                                              Resume[]
  subscriptions                                        Subscription[]
  tutorArtifacts                                       TutorArtifact[]
  tutorChatMessages                                    TutorChatMessage[]
  tutorConversations                                   TutorConversation[]
  tutorMemories                                        TutorMemory[]
  tutorToolCallLogs                                    TutorToolCallLog[]
  mistakes                                             UserMistake[]
  questionProgress                                     UserQuestionProgress[]
  questionSubmissions                                  UserQuestionSubmission[]
  tutorProfile                                         UserTutorProfile?
  weakAreas                                            UserWeakArea[]
  verificationCodes                                    VerificationCode[]
  jobApplications                                      JobApplication[]
  notifications                                        UserNotification[]
  technicalAssignmentSubmissions                       TechnicalAssignmentSubmission[]
  jobRoundCandidates                                   JobRoundCandidate[]
  jobRoundEvaluationReports                            JobRoundEvaluationReport[]
  directInterviews                                     DirectInterview[]
  directInterviewMessages                              DirectInterviewMessage[]
  secureOaSessions                                     SecureOaSession[]                  @relation("SecureOaSessionCandidate")
  expertProfile                                        expert_profiles?
  expertBookingRequests                                expert_booking_requests[]
  expertBookingSlotsClaimed                            expert_booking_slots[]              @relation("ExpertBookingSlotClaimedBy")
  expertSessionsAsCandidate                            expert_sessions[]                   @relation("ExpertSessionCandidate")
  expertSessionsAsExpert                               expert_sessions[]                   @relation("ExpertSessionExpert")
  expertSessionQuestionsAdded                          expert_session_questions[]
  expertFeedbackGiven                                  expert_feedback[]                   @relation("ExpertFeedbackExpert")
  expertFeedbackReceived                               expert_feedback[]                   @relation("ExpertFeedbackCandidate")
  contestsCreated                                      Contest[]                           @relation("ContestCreator")
  contestTestingListsOwned                             ContestTestingTester[]              @relation("ContestTestingOwner")
  contestTestingListsIncludedIn                        ContestTestingTester[]              @relation("ContestTestingUser")

  @@index([role])
  @@index([placementCollegeEmailDomain])
  @@map("users")
}

model Company {
  id                 String   @id @default(uuid())
  email              String   @unique
  name               String   @map("name")
  domain             String   @map("domain")
  contactName        String?  @map("contact_name")
  websiteUrl         String?  @map("website_url")
  logoUrl            String?  @map("logo_url")
  industry           String?
  companySize        String?  @map("company_size")
  headquarters       String?
  defaultTimezone    String   @default("Asia/Kolkata") @map("default_timezone")
  defaultWorkMode    String   @default("Hybrid") @map("default_work_mode")
  defaultEmploymentType String @default("Full-time") @map("default_employment_type")
  defaultCurrency    String   @default("INR") @map("default_currency")
  defaultAssessmentDeadlineDays Int @default(7) @map("default_assessment_deadline_days")
  notifyNewApplications Boolean @default(true) @map("notify_new_applications")
  notifyAssessmentSubmissions Boolean @default(true) @map("notify_assessment_submissions")
  notifyWeeklyDigest Boolean @default(true) @map("notify_weekly_digest")
  notifyTeamChanges  Boolean  @default(true) @map("notify_team_changes")
  lastLoginAt        DateTime? @map("last_login_at")
  lastLoginIp        String?  @map("last_login_ip")
  lastLoginLocation  String?  @map("last_login_location")
  emailVerified      Boolean  @default(false) @map("email_verified")
  emailVerifiedAt    DateTime? @map("email_verified_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  verificationCodes  CompanyVerificationCode[]
  jobOpenings        CompanyJobOpening[]
  technicalAssignments TechnicalAssignment[]
  jobRounds          JobRound[]
  teams              CompanyTeam[]                     @relation("CompanyTeams")
  createdTeams       CompanyTeam[]                     @relation("CompanyTeamsCreated")
  teamMembers        CompanyTeamMember[]               @relation("CompanyTeamMembers")
  addedTeamMembers   CompanyTeamMember[]               @relation("CompanyTeamMembersAddedBy")
  teamInvitations    CompanyTeamInvitation[]           @relation("CompanyTeamInvitations")
  sentTeamInvitations CompanyTeamInvitation[]           @relation("CompanyTeamInvitationsSentBy")
  directInterviews   DirectInterview[]
  secureOaSessions   SecureOaSession[]

  @@map("companies")
}

model CompanyMemberAccount {
  id                  String                          @id
  email               String                          @unique
  fullName            String                          @map("full_name")
  avatarUrl           String?                         @map("avatar_url")
  lastLoginAt         DateTime?                       @map("last_login_at")
  lastLoginIp         String?                         @map("last_login_ip")
  lastLoginLocation   String?                         @map("last_login_location")
  emailVerified       Boolean                         @default(false) @map("email_verified")
  emailVerifiedAt     DateTime?                       @map("email_verified_at")
  createdAt           DateTime                        @default(now()) @map("created_at")
  updatedAt           DateTime                        @updatedAt @map("updated_at")
  verificationCodes   CompanyMemberVerificationCode[]
  teamMemberships     CompanyTeamMember[]             @relation("CompanyTeamMemberAccounts")
  acceptedInvitations CompanyTeamInvitation[]          @relation("AcceptedCompanyTeamInvitationAccounts")

  @@map("company_member_accounts")
}

model CompanyJobOpening {
  id                  String    @id @default(uuid())
  companyId           String    @map("company_id")
  companyName         String    @map("company_name")
  companyLogoUrl      String?   @map("company_logo_url")
  title               String
  location            String
  workMode            String    @map("work_mode")
  employmentType      String    @map("employment_type")
  roleType            String    @map("role_type")
  profession          String
  discipline          String
  travel              String
  openings            Int       @default(1)
  experienceLevel     String    @map("experience_level")
  compensationType    String    @map("compensation_type")
  compensation        String?
  duration            String?
  timeCommitment      String?   @map("time_commitment")
  applicationDeadline DateTime? @map("application_deadline")
  skills              String[]  @default([])
  companyOverview     String?   @map("company_overview") @db.Text
  aboutRole           String    @map("about_role") @db.Text
  responsibilities    String[]  @default([])
  requirements        String[]  @default([])
  benefits            String[]  @default([])
  applicationNote     String?   @map("application_note") @db.Text
  scoringConfig       Json?     @map("scoring_config")
  nextRoundType       String?   @map("next_round_type")
  nextRoundConfiguredAt DateTime? @map("next_round_configured_at")
  currentRoundType    String?   @map("current_round_type")
  currentRoundResourceId String? @map("current_round_resource_id")
  currentRoundConfiguredAt DateTime? @map("current_round_configured_at")
  status              String    @default("draft")
  publishedAt         DateTime? @map("published_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  company             Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications         JobApplication[]
  technicalAssignments TechnicalAssignment[]
  rounds               JobRound[]
  directInterviews     DirectInterview[]

  @@index([companyId, status, createdAt])
  @@index([status, employmentType, workMode])
  @@map("company_job_openings")
}

model CompanyVerificationCode {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  type      String
  code      String
  target    String
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, type, verified])
  @@index([code, expiresAt])
  @@map("company_verification_codes")
}

model CompanyMemberVerificationCode {
  id               String               @id @default(uuid())
  companyAccountId String               @map("company_account_id")
  type             String
  code             String
  target           String
  expiresAt        DateTime             @map("expires_at")
  verified         Boolean              @default(false)
  attempts         Int                  @default(0)
  createdAt        DateTime             @default(now()) @map("created_at")
  account          CompanyMemberAccount @relation(fields: [companyAccountId], references: [id], onDelete: Cascade)

  @@index([companyAccountId, type, verified])
  @@index([code, expiresAt])
  @@map("company_member_verification_codes")
}

model CompanyTeam {
  id            String                  @id @default(uuid())
  companyId     String                  @map("company_id")
  name          String
  description   String?
  avatarColor   String?                 @map("avatar_color")
  createdById   String                  @map("created_by_id")
  isArchived    Boolean                 @default(false) @map("is_archived")
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")
  company       Company                 @relation("CompanyTeams", fields: [companyId], references: [id], onDelete: Cascade)
  createdBy     Company                 @relation("CompanyTeamsCreated", fields: [createdById], references: [id], onDelete: Restrict)
  members       CompanyTeamMember[]
  invitations   CompanyTeamInvitation[]

  @@index([companyId, isArchived, createdAt])
  @@map("company_teams")
}

model CompanyTeamMember {
  id             String                 @id @default(uuid())
  companyId      String                 @map("company_id")
  teamId         String                 @map("team_id")
  companyAccountId String?              @map("company_account_id")
  invitationId   String?                @unique @map("invitation_id")
  email          String
  nameHint       String?                @map("name_hint")
  role           String                 @default("member")
  status         String                 @default("active")
  joinedAt       DateTime?              @map("joined_at")
  addedById      String                 @map("added_by_id")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  company        Company                @relation("CompanyTeamMembers", fields: [companyId], references: [id], onDelete: Cascade)
  addedBy        Company                @relation("CompanyTeamMembersAddedBy", fields: [addedById], references: [id], onDelete: Restrict)
  team           CompanyTeam            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  account        CompanyMemberAccount?  @relation("CompanyTeamMemberAccounts", fields: [companyAccountId], references: [id], onDelete: SetNull)
  invitation     CompanyTeamInvitation? @relation(fields: [invitationId], references: [id], onDelete: SetNull)
  assignedDirectInterviews DirectInterview[]
  sentDirectInterviewMessages DirectInterviewMessage[]
  addedDirectInterviewQuestions DirectInterviewQuestion[]

  @@unique([teamId, email])
  @@unique([teamId, companyAccountId])
  @@index([companyId, status])
  @@index([companyAccountId, status])
  @@map("company_team_members")
}

model CompanyTeamInvitation {
  id               String             @id @default(uuid())
  companyId        String             @map("company_id")
  teamId           String             @map("team_id")
  invitedById      String             @map("invited_by_id")
  acceptedByCompanyAccountId String?  @map("accepted_by_company_account_id")
  email            String
  tokenHash        String             @unique @map("token_hash")
  role             String             @default("member")
  status           String             @default("pending")
  expiresAt        DateTime           @map("expires_at")
  acceptedAt       DateTime?          @map("accepted_at")
  metadata         Json?
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  company          Company            @relation("CompanyTeamInvitations", fields: [companyId], references: [id], onDelete: Cascade)
  team             CompanyTeam        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inviter          Company            @relation("CompanyTeamInvitationsSentBy", fields: [invitedById], references: [id], onDelete: Restrict)
  acceptedByAccount CompanyMemberAccount? @relation("AcceptedCompanyTeamInvitationAccounts", fields: [acceptedByCompanyAccountId], references: [id], onDelete: SetNull)
  member           CompanyTeamMember?

  @@index([companyId, status, createdAt])
  @@index([teamId, status])
  @@index([email, status, expiresAt])
  @@map("company_team_invitations")
}

model VerificationCode {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  code      String
  target    String
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, verified])
  @@index([code, expiresAt])
  @@map("verification_codes")
}

model Resume {
  id          String             @id @default(uuid())
  userId      String             @map("user_id")
  fileName    String             @map("file_name")
  fileUrl     String             @map("file_url")
  rawText     String?            @map("raw_text")
  analysis    Json?
  uploadedAt  DateTime           @default(now()) @map("uploaded_at")
  atsAnalysis Json?              @map("ats_analysis")
  sessions    InterviewSession[]
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resumes")
}

model JobApplyProfile {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  profileLanguage  String   @default("English") @map("profile_language")
  pronouns         String?
  headline         String?
  industry         String?
  city             String?
  country          String?
  postalCode       String?  @map("postal_code")
  about            String?
  openTo           String?  @map("open_to")
  coverImageUrl    String?  @map("cover_image_url")
  selectedResumeId String?  @map("selected_resume_id")
  leetcodeUrl      String?  @map("leetcode_url")
  geeksforgeeksUrl String?  @map("geeksforgeeks_url")
  codeforcesUrl    String?  @map("codeforces_url")
  codechefUrl      String?  @map("codechef_url")
  experiences      Json?    @default("[]")
  education        Json?    @default("[]")
  skills           Json?    @default("[]")
  featured         Json?    @default("[]")
  projects         Json?    @default("[]")
  isPublished      Boolean  @default(false) @map("is_published")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isPublished])
  @@map("job_apply_profiles")
}

model JobApplication {
  id                    String   @id @default(uuid())
  jobId                 String   @map("job_id")
  userId                String   @map("user_id")
  selectedProjects      Json     @default("[]") @map("selected_projects")
  githubProfileSnapshot Json?    @map("github_profile_snapshot")
  githubAnalysis        Json?    @map("github_analysis")
  codingProfiles        Json?    @map("coding_profiles")
  codingAnalysis        Json?    @map("coding_analysis")
  evidencePack          Json?    @map("evidence_pack")
  recruiterAnalysis     Json?    @map("recruiter_analysis")
  recruiterReport       Json?    @map("recruiter_report")
  nextRoundType         String?  @map("next_round_type")
  nextRoundMovedAt      DateTime? @map("next_round_moved_at")
  status                String   @default("submitted")
  submittedAt           DateTime @default(now()) @map("submitted_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  job                   CompanyJobOpening @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  technicalAssignmentSubmissions TechnicalAssignmentSubmission[]
  roundCandidates       JobRoundCandidate[]
  jobRoundEvaluationReports JobRoundEvaluationReport[]
  directInterviews      DirectInterview[]

  @@unique([jobId, userId])
  @@index([jobId, submittedAt])
  @@index([userId, submittedAt])
  @@map("job_applications")
}

model TechnicalAssignment {
  id                     String   @id @default(uuid())
  companyId              String   @map("company_id")
  jobId                  String   @map("job_id")
  roundId                String?  @unique @map("round_id")
  title                  String
  timeLimit              String   @map("time_limit")
  estimatedHours         String?  @map("estimated_hours")
  deadlinePolicy         String?  @map("deadline_policy") @db.Text
  overview               String   @db.Text
  scenario               String   @db.Text
  tasks                  String[] @default([])
  starterContext         String?  @map("starter_context") @db.Text
  constraints            String[] @default([])
  allowedStack           String[] @default([]) @map("allowed_stack")
  deliverables           String[] @default([])
  submissionInstructions String?  @map("submission_instructions") @db.Text
  thinkingQuestions      String[] @default([]) @map("thinking_questions")
  candidateMessage       String?  @map("candidate_message") @db.Text
  rubric                 Json
  status                 String   @default("live")
  closesAt               DateTime @map("closes_at")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")
  company                Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job                    CompanyJobOpening @relation(fields: [jobId], references: [id], onDelete: Cascade)
  round                  JobRound? @relation(fields: [roundId], references: [id], onDelete: SetNull)
  submissions            TechnicalAssignmentSubmission[]

  @@index([companyId, closesAt])
  @@index([jobId, closesAt])
  @@index([status, closesAt])
  @@map("technical_assignments")
}

model TechnicalAssignmentSubmission {
  id            String   @id @default(uuid())
  assignmentId  String   @map("assignment_id")
  userId        String   @map("user_id")
  applicationId String?  @map("application_id")
  repoUrl       String   @map("repo_url")
  status        String   @default("submitted")
  score         Int      @default(0)
  evidence      Json?
  report        Json?
  nextRoundType String?  @map("next_round_type")
  nextRoundMovedAt DateTime? @map("next_round_moved_at")
  roundCandidateId String? @map("round_candidate_id")
  submittedAt   DateTime @default(now()) @map("submitted_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  assignment    TechnicalAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   JobApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  roundCandidate JobRoundCandidate? @relation(fields: [roundCandidateId], references: [id], onDelete: SetNull)

  @@unique([assignmentId, userId])
  @@index([assignmentId, submittedAt])
  @@index([userId, submittedAt])
  @@index([applicationId])
  @@index([roundCandidateId])
  @@map("technical_assignment_submissions")
}

model JobRound {
  id              String   @id @default(uuid())
  jobId           String   @map("job_id")
  companyId       String   @map("company_id")
  roundNumber     Int      @map("round_number")
  roundType       String   @map("round_type")
  title           String
  status          String   @default("draft")
  opensAt         DateTime? @map("opens_at")
  closesAt        DateTime? @map("closes_at")
  resourceId      String?  @map("resource_id")
  config          Json?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  job             CompanyJobOpening @relation(fields: [jobId], references: [id], onDelete: Cascade)
  company         Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidates      JobRoundCandidate[]
  reports         JobRoundEvaluationReport[]
  technicalAssignment TechnicalAssignment?
  directInterviews DirectInterview[]
  secureOaSessions SecureOaSession[]
  proctoringRules ProctoringRule[]

  @@unique([jobId, roundNumber])
  @@index([companyId, status, createdAt])
  @@index([jobId, roundType, status])
  @@map("job_rounds")
}

model JobRoundCandidate {
  id              String   @id @default(uuid())
  roundId         String   @map("round_id")
  applicationId   String   @map("application_id")
  userId          String   @map("user_id")
  status          String   @default("invited")
  advanced        Boolean  @default(false)
  score           Int      @default(0)
  metadata        Json?
  submittedAt     DateTime? @map("submitted_at")
  evaluatedAt     DateTime? @map("evaluated_at")
  advancedAt      DateTime? @map("advanced_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  round           JobRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  application     JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
  report          JobRoundEvaluationReport?
  technicalAssignmentSubmissions TechnicalAssignmentSubmission[]
  directInterview DirectInterview?
  secureOaSessions SecureOaSession[]

  @@unique([roundId, applicationId])
  @@index([roundId, status, score])
  @@index([applicationId, createdAt])
  @@index([userId, createdAt])
  @@map("job_round_candidates")
}

model SecureOaSession {
  id                     String              @id @default(uuid())
  jobRoundId             String              @map("job_round_id")
  jobRoundCandidateId    String              @map("job_round_candidate_id")
