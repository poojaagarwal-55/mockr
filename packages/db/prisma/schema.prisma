// ============================================================================
// CONTEST PLATFORM MODELS
// ============================================================================
// Added: 2026-05-07
// Purpose: Scalable contest platform for coding competitions
// Reference: .kiro/specs/scalable-contest-platform/SCHEMA_REFERENCE.md
// ============================================================================

enum ContestStatus {
  UPCOMING  // Contest not started yet
  ACTIVE    // Contest is currently running
  ENDED     // Contest has finished
  CANCELLED // Contest was cancelled
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum SubmissionStatus {
  QUEUED                    // Submission is in queue
  PROCESSING                // Submission is being executed
  JUDGING_DEFERRED          // Judge0 infrastructure failed; retry is pending
  ACCEPTED                  // All test cases passed
  WRONG_ANSWER              // Some test cases failed
  TIME_LIMIT_EXCEEDED       // Execution took too long
  MEMORY_LIMIT_EXCEEDED     // Used too much memory
  RUNTIME_ERROR             // Code crashed during execution
  COMPILATION_ERROR         // Code failed to compile
}

model Contest {
  id            String              @id @default(cuid())
  title         String
  description   String?
  instructions  String              @default("Stay in fullscreen until you submit or the timer ends.\nKeep this contest tab focused. Switching windows, changing tabs, or leaving the page records an integrity warning.\nWrite and run code only inside the contest editor.\nCopying question text is blocked. Pasting from outside the contest editor is blocked.\nUse only the information provided in the problem statements and sample tests.\nSubmit before the timer reaches zero. After submission, you cannot attempt more questions.") @db.Text
  showDifficultyTags Boolean        @default(true) @map("show_difficulty_tags")
  showParticipants Boolean          @default(false) @map("show_participants")
  isArchived    Boolean             @default(false) @map("is_archived")
  isUnderTesting Boolean            @default(false) @map("is_under_testing")
  createdById   String?             @map("created_by_id")
  startTime     DateTime            @map("start_time")
  endTime       DateTime            @map("end_time")
  status        ContestStatus       @default(UPCOMING)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  
  createdBy     User?               @relation("ContestCreator", fields: [createdById], references: [id], onDelete: SetNull)
  questions     ContestQuestion[]
  participants  ContestParticipant[]
  submissions   ContestSubmission[]
  feedback      ContestFeedback[]

  @@index([createdById])
  @@index([isArchived, isUnderTesting])
  @@map("contests")
}

model ContestTestingTester {
  id           String   @id @default(cuid())
  ownerId      String   @map("owner_id")
  testerUserId String   @map("tester_user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  owner        User     @relation("ContestTestingOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  tester       User     @relation("ContestTestingUser", fields: [testerUserId], references: [id], onDelete: Cascade)

  @@unique([ownerId, testerUserId])
  @@index([ownerId])
  @@index([testerUserId])
  @@map("contest_testing_testers")
}

model ContestQuestion {
  id          String              @id @default(cuid())
  contestId   String              @map("contest_id")
  questionId  String              @map("question_id")  // Reference to MongoDB question
  difficulty  Difficulty
  points      Int                 // 150, 300, or 500
  negativePoints Int              @default(0) @map("negative_points")
  negativeCap Int                 @default(0) @map("negative_cap")
  order       Int                 // Display order in contest
  
  contest     Contest             @relation(fields: [contestId], references: [id], onDelete: Cascade)
  submissions ContestSubmission[]
  
  @@unique([contestId, questionId])
  @@index([contestId])
  @@map("contest_questions")
}

model ContestParticipant {
  id             String    @id @default(cuid())
  contestId      String    @map("contest_id")
  userId         String    @map("user_id")
  registeredAt   DateTime  @default(now()) @map("registered_at")
  totalScore     Int       @default(0) @map("total_score")
  submittedAt    DateTime? @map("submitted_at")
  isSubmitted    Boolean   @default(false) @map("is_submitted")
  submissionType String    @default("manual") @map("submission_type") // manual, auto_time, auto_tab_switch, auto_window_blur, auto_fullscreen_exit, auto_cheating
  
  contest        Contest   @relation(fields: [contestId], references: [id], onDelete: Cascade)
  
  @@unique([contestId, userId])
  @@index([contestId, totalScore, registeredAt])
  @@index([contestId, isSubmitted])
  @@index([userId])
  @@map("contest_participants")
}

model ContestSubmission {
  id               String           @id @default(cuid())
  contestId        String           @map("contest_id")
  questionId       String           @map("question_id")
  userId           String           @map("user_id")
  code             String           @db.Text
  language         String
  status           SubmissionStatus
  attemptNumber    Int              @map("attempt_number")  // 1-5
  pointsAwarded    Int              @map("points_awarded")  // +150/+300/+500 or -50
  executionTime    Int?             @map("execution_time")  // milliseconds
  memoryUsed       Int?             @map("memory_used")     // KB
  testCasesPassed  Int              @default(0) @map("test_cases_passed")
  testCasesTotal   Int              @map("test_cases_total")
  idempotencyKey   String           @unique @map("idempotency_key")
  submittedAt      DateTime         @default(now()) @map("submitted_at")
  
  contest          Contest          @relation(fields: [contestId], references: [id], onDelete: Cascade)
  question         ContestQuestion  @relation(fields: [contestId, questionId], references: [contestId, questionId], onDelete: Cascade)
  
  @@index([contestId, userId, questionId])
  @@index([contestId, questionId, attemptNumber])
  @@index([userId, contestId])
  @@index([idempotencyKey])
  @@map("contest_submissions")
}

model ContestFeedback {
  id        String   @id @default(cuid())
  contestId String   @map("contest_id")
  userId    String   @map("user_id")
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId])
  @@index([contestId, rating])
  @@index([userId])
  @@map("contest_feedback")
}

/// Expert interview platform — expert-specific profile (1:1 to User where isExpert=true).
/// Lazy-created on first read so admin grant is just an isExpert flip.
model expert_profiles {
  id                 String   @id
  user_id            String   @unique
  bio                String?
  expertise_tags     String[] @default([])
  years_experience   Int?
  accepting_bookings Boolean  @default(true)
  rating_avg         Decimal? @db.Decimal(3, 2)
  sessions_completed Int      @default(0)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  users              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([accepting_bookings])
}

/// Candidate-side request: "I want an expert interview, here are my preferences."
/// Carries the per-request status; the individual time windows live on expert_booking_slots.
model expert_booking_requests {
  id                  String                 @id
  candidate_user_id   String
  interview_type      String                 @default("coding")
  preferred_language  String                 @default("python")
  level               String                 @default("beginner")
  topics_focus        String[]               @default([])
  notes               String?
  status              String                 @default("open")
  expires_at          DateTime
  created_at          DateTime               @default(now())
  updated_at          DateTime               @updatedAt
  users               User                   @relation(fields: [candidate_user_id], references: [id], onDelete: Cascade)
  slots               expert_booking_slots[]

  @@index([status, created_at])
  @@index([status, expires_at])
  @@index([candidate_user_id, status])
}

/// Candidate-offered free windows on a booking request. The expert atomically claims
/// one of these (UPDATE ... WHERE claimed_by_expert_id IS NULL); first write wins, the
/// other windows on the same request are then expired by the booking-request close path.
model expert_booking_slots {
  id                    String                  @id
  request_id            String
  start_at              DateTime
  end_at                DateTime
  candidate_timezone    String?
  claimed_by_expert_id  String?
  claimed_at            DateTime?
  resulting_session_id  String?                 @unique
  created_at            DateTime                @default(now())
  request               expert_booking_requests @relation(fields: [request_id], references: [id], onDelete: Cascade)
  claimedBy             User?                   @relation("ExpertBookingSlotClaimedBy", fields: [claimed_by_expert_id], references: [id])

  @@index([request_id])
  @@index([claimed_by_expert_id])
  @@index([start_at, claimed_by_expert_id])
}

/// Materialised expert session — created when the expert claims a slot. Mirrors the
/// peer_sessions lifecycle (SCHEDULED → CONNECTING → ACTIVE → COMPLETED / CANCELLED /
/// ABANDONED) so the existing socket / WebRTC plumbing in apps/p2p can be reused
/// without forking a new state machine.
model expert_sessions {
  id                 String                     @id
  room_id            String                     @unique
  request_id         String?
  slot_id            String?                    @unique
  candidate_user_id  String
  expert_user_id     String
  interview_type     String                     @default("coding")
  preferred_language String                     @default("python")
  status             String                     @default("SCHEDULED")
  scheduled_for      DateTime
  ends_at            DateTime?
  started_at         DateTime?
  candidate_admitted_at DateTime?
  ended_at           DateTime?
  created_at         DateTime                   @default(now())
  updated_at         DateTime                   @updatedAt
  candidate          User                       @relation("ExpertSessionCandidate", fields: [candidate_user_id], references: [id], onDelete: Cascade)
  expert             User                       @relation("ExpertSessionExpert", fields: [expert_user_id], references: [id], onDelete: Cascade)
  questions          expert_session_questions[]
  feedback           expert_feedback[]

  @@index([status, scheduled_for])
  @@index([candidate_user_id, scheduled_for])
  @@index([expert_user_id, scheduled_for])
}

/// Questions the expert lined up for a session, ordered. question_id is a FK into the
/// DSAQuestion mongo collection for platform questions; null + custom_prompt = expert
/// pasted a one-off question we don't persist to the bank.
model expert_session_questions {
  id                  String          @id
  session_id          String
  question_id         String?
  question_title      String
  question_difficulty String
  question_topic      String
  is_custom           Boolean         @default(false)
  custom_prompt       String?
  order_index         Int
  added_by_user_id    String
  created_at          DateTime        @default(now())
  session             expert_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)
  addedBy             User            @relation(fields: [added_by_user_id], references: [id])

  @@unique([session_id, order_index])
  @@index([session_id])
}

/// Structured expert feedback for a session. shared_with_candidate gates visibility of
/// the public fields; private_notes is expert-only forever.
model expert_feedback {
  id                    String          @id
  session_id            String          @unique
  expert_user_id        String
  candidate_user_id     String
  problem_solving       Int
  communication         Int
  code_quality          Int
  technical_depth       Int
  overall_rating        Int
  hire_decision         String
  strengths             String?
  improvement_areas     String?
  private_notes         String?
  shared_with_candidate Boolean         @default(false)
  created_at            DateTime        @default(now())
  session               expert_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)
  expert                User            @relation("ExpertFeedbackExpert", fields: [expert_user_id], references: [id], onDelete: Cascade)
  candidate             User            @relation("ExpertFeedbackCandidate", fields: [candidate_user_id], references: [id], onDelete: Cascade)

  @@index([candidate_user_id, created_at])
  @@index([expert_user_id, created_at])
}
